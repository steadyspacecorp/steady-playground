# Long-lived OAuth token for headless claude -p (run `claude setup-token` on your Mac)
CLAUDE_CODE_OAUTH_TOKEN=

# Steady activity webhook, including the token query param
# https://runsteady.com/docs/article/27-webhook/
STEADY_WEBHOOK_URL=https://service.steady.space/hooks/activity/a/YOUR_ID?token=YOUR_TOKEN

# Email associated with the Steady activities
STEADY_EMAIL=you@example.com

# Use each project's GitHub origin remote as the activity source_url,
# falling back to SOURCE_URL. Set to false to always use SOURCE_URL.
USE_GIT_ORIGIN_SOURCE_URL=true

# Optional: source_url for activities whose project has no GitHub origin
# remote (or for all activities when USE_GIT_ORIGIN_SOURCE_URL=false).
# When unset, those activities are posted without a source_url.
# SOURCE_URL=https://runsteady.com

# How often to summarize and post (hours)
INTERVAL_HOURS=6

# Optional: comma-separated host project paths to limit which projects are
# summarized. Empty = all projects in ~/.claude/projects.
# PROJECT_DIRS=/Users/you/Developer/steady,/Users/you/Developer/other

# Optional: where Claude Code session transcripts live on the host
# CLAUDE_PROJECTS_DIR=~/.claude/projects

# Optional: model used for summarization
CLAUDE_MODEL=claude-sonnet-4-6
