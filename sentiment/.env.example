# Steady personal access token (starts with steady_pat_).
# Create one at https://app.steady.space/my/integrations/edit
STEADY_PAT=steady_pat_xxx

# Team scope: "my" (teams the token's person belongs to, the default)
# or "all" (every team the token can see).
STEADY_SCOPE=my

# Optional: comma-separated team UUIDs to score. Overrides STEADY_SCOPE.
STEADY_TEAM_IDS=

# Timezone used for the check-in date window.
TZ=America/New_York

# How often (seconds) the server polls the Steady API and re-scores.
# Each poll costs roughly 2-3 requests against the PAT's 500-per-30-minute
# budget; scoring only re-runs when the check-ins actually changed.
POLL_SECONDS=600

# How many days back to look for the most recent day with check-ins.
LOOKBACK_DAYS=7

# Where to cache the model weights (~150MB on first run).
MODELS_DIR=./tmp/models
