# Steady personal access token (starts with steady_pat_).
# Create one at https://app.steady.space/my/integrations/edit
STEADY_PAT=steady_pat_xxx

# Team scope: "my" (teams the token's person belongs to, the default)
# or "all" (every team the token can see).
STEADY_SCOPE=my

# Optional: comma-separated team UUIDs to display. Overrides STEADY_SCOPE.
STEADY_TEAM_IDS=

# Timezone used to resolve "today" for check-ins.
TZ=America/New_York

# How often (seconds) the server polls the Steady API and pushes
# updates to connected pages. Each poll costs roughly 4 + (number of
# goals) requests against the PAT's 500-per-30-minute budget.
POLL_SECONDS=300
